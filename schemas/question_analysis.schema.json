{
  "$defs": {
    "AnalysisMode": {
      "enum": [
        "light",
        "analyst"
      ],
      "title": "AnalysisMode",
      "type": "string"
    },
    "AnalysisRequirementsInfo": {
      "additionalProperties": false,
      "properties": {
        "needs_driver_analysis": {
          "default": false,
          "title": "Needs Driver Analysis",
          "type": "boolean"
        },
        "needs_trend_context": {
          "default": false,
          "title": "Needs Trend Context",
          "type": "boolean"
        },
        "needs_correlation_context": {
          "default": false,
          "title": "Needs Correlation Context",
          "type": "boolean"
        },
        "derived_metrics": {
          "items": {
            "$ref": "#/$defs/DerivedMetricRequest"
          },
          "maxItems": 12,
          "title": "Derived Metrics",
          "type": "array"
        }
      },
      "title": "AnalysisRequirementsInfo",
      "type": "object"
    },
    "AnswerKind": {
      "description": "Shape of the final answer the user expects.",
      "enum": [
        "scalar",
        "list",
        "timeseries",
        "comparison",
        "explanation",
        "forecast",
        "scenario",
        "knowledge",
        "clarify"
      ],
      "title": "AnswerKind",
      "type": "string"
    },
    "ChartFamily": {
      "enum": [
        "line",
        "bar",
        "stacked",
        "pie",
        "dualaxis"
      ],
      "title": "ChartFamily",
      "type": "string"
    },
    "ChartIntent": {
      "enum": [
        "trend_compare",
        "decomposition"
      ],
      "title": "ChartIntent",
      "type": "string"
    },
    "ClassificationInfo": {
      "additionalProperties": false,
      "properties": {
        "query_type": {
          "$ref": "#/$defs/QueryType"
        },
        "analysis_mode": {
          "$ref": "#/$defs/AnalysisMode"
        },
        "intent": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Intent",
          "type": "string"
        },
        "needs_clarification": {
          "title": "Needs Clarification",
          "type": "boolean"
        },
        "confidence": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "ambiguities": {
          "items": {
            "type": "string"
          },
          "maxItems": 25,
          "title": "Ambiguities",
          "type": "array"
        }
      },
      "required": [
        "query_type",
        "analysis_mode",
        "intent",
        "needs_clarification",
        "confidence"
      ],
      "title": "ClassificationInfo",
      "type": "object"
    },
    "DerivedMetricName": {
      "enum": [
        "mom_absolute_change",
        "mom_percent_change",
        "yoy_absolute_change",
        "yoy_percent_change",
        "share_delta_mom",
        "correlation_to_target",
        "trend_slope",
        "scenario_scale",
        "scenario_offset",
        "scenario_payoff"
      ],
      "title": "DerivedMetricName",
      "type": "string"
    },
    "DerivedMetricRequest": {
      "additionalProperties": false,
      "properties": {
        "metric_name": {
          "$ref": "#/$defs/DerivedMetricName"
        },
        "metric": {
          "maxLength": 64,
          "minLength": 1,
          "title": "Metric",
          "type": "string"
        },
        "target_metric": {
          "anyOf": [
            {
              "maxLength": 64,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Target Metric"
        },
        "rank_limit": {
          "anyOf": [
            {
              "maximum": 10,
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Rank Limit"
        },
        "scenario_factor": {
          "anyOf": [
            {
              "maximum": 1000000000.0,
              "minimum": -1000000000.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Scenario Factor"
        },
        "scenario_volume": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "maximum": 1000000.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Scenario Volume"
        },
        "scenario_aggregation": {
          "anyOf": [
            {
              "$ref": "#/$defs/ScenarioAggregation"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "season": {
          "anyOf": [
            {
              "$ref": "#/$defs/Season"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "metric_name",
        "metric"
      ],
      "title": "DerivedMetricRequest",
      "type": "object"
    },
    "DimensionName": {
      "enum": [
        "price",
        "xrate",
        "share",
        "tariff",
        "energy_qty",
        "generation",
        "cpi",
        "seasonality",
        "market_structure",
        "entity",
        "power_plant",
        "regulation_status",
        "period"
      ],
      "title": "DimensionName",
      "type": "string"
    },
    "EvidenceRole": {
      "description": "Semantic role of a dataset in a multi-evidence execution plan.",
      "enum": [
        "primary_data",
        "composition_context",
        "tariff_context",
        "correlation_driver"
      ],
      "title": "EvidenceRole",
      "type": "string"
    },
    "FilterCondition": {
      "additionalProperties": false,
      "description": "Value-based filter applied during evidence collection (after fetch, before framing).",
      "properties": {
        "metric": {
          "maxLength": 64,
          "minLength": 1,
          "title": "Metric",
          "type": "string"
        },
        "operator": {
          "$ref": "#/$defs/FilterOperator"
        },
        "value": {
          "title": "Value",
          "type": "number"
        },
        "unit": {
          "anyOf": [
            {
              "maxLength": 16,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Unit"
        }
      },
      "required": [
        "metric",
        "operator",
        "value"
      ],
      "title": "FilterCondition",
      "type": "object"
    },
    "FilterOperator": {
      "description": "Comparison operators for value-based evidence filtering.",
      "enum": [
        "gt",
        "gte",
        "lt",
        "lte",
        "eq"
      ],
      "title": "FilterOperator",
      "type": "string"
    },
    "Grouping": {
      "description": "How the answer rows should be grouped in the final output.",
      "enum": [
        "none",
        "by_entity",
        "by_period",
        "by_metric"
      ],
      "title": "Grouping",
      "type": "string"
    },
    "KnowledgeInfo": {
      "additionalProperties": false,
      "properties": {
        "candidate_topics": {
          "items": {
            "$ref": "#/$defs/TopicCandidate"
          },
          "maxItems": 5,
          "title": "Candidate Topics",
          "type": "array"
        }
      },
      "title": "KnowledgeInfo",
      "type": "object"
    },
    "KnowledgeTopicName": {
      "enum": [
        "general_definitions",
        "balancing_price",
        "market_structure",
        "tariffs",
        "cfd_ppa",
        "currency_influence",
        "seasonal_patterns",
        "generation_mix",
        "pso_trading",
        "sql_examples"
      ],
      "title": "KnowledgeTopicName",
      "type": "string"
    },
    "LanguageCode": {
      "enum": [
        "en",
        "ka",
        "ru",
        "zh",
        "other"
      ],
      "title": "LanguageCode",
      "type": "string"
    },
    "LanguageInfo": {
      "additionalProperties": false,
      "properties": {
        "input_language": {
          "$ref": "#/$defs/LanguageCode"
        },
        "answer_language": {
          "$ref": "#/$defs/LanguageCode"
        }
      },
      "required": [
        "input_language",
        "answer_language"
      ],
      "title": "LanguageInfo",
      "type": "object"
    },
    "MeasureTransform": {
      "enum": [
        "raw",
        "sum",
        "avg",
        "weighted_avg",
        "share_of_total",
        "mom_delta",
        "mom_pct",
        "yoy_delta",
        "yoy_pct",
        "cagr",
        "index_100"
      ],
      "title": "MeasureTransform",
      "type": "string"
    },
    "PeriodGranularity": {
      "enum": [
        "day",
        "month",
        "quarter",
        "year",
        "range",
        "relative"
      ],
      "title": "PeriodGranularity",
      "type": "string"
    },
    "PeriodInfo": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "$ref": "#/$defs/PeriodKind"
        },
        "start_date": {
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "title": "Start Date",
          "type": "string"
        },
        "end_date": {
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "title": "End Date",
          "type": "string"
        },
        "granularity": {
          "$ref": "#/$defs/PeriodGranularity"
        },
        "raw_text": {
          "anyOf": [
            {
              "maxLength": 120,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Raw Text"
        }
      },
      "required": [
        "kind",
        "start_date",
        "end_date",
        "granularity"
      ],
      "title": "PeriodInfo",
      "type": "object"
    },
    "PeriodKind": {
      "enum": [
        "day",
        "month",
        "quarter",
        "year",
        "range",
        "relative"
      ],
      "title": "PeriodKind",
      "type": "string"
    },
    "PreferredPath": {
      "enum": [
        "knowledge",
        "tool",
        "sql",
        "clarify",
        "reject"
      ],
      "title": "PreferredPath",
      "type": "string"
    },
    "PresentationMode": {
      "enum": [
        "chart",
        "table",
        "text",
        "chart_plus_table"
      ],
      "title": "PresentationMode",
      "type": "string"
    },
    "QueryType": {
      "enum": [
        "conceptual_definition",
        "regulatory_procedure",
        "factual_lookup",
        "data_retrieval",
        "data_explanation",
        "comparison",
        "forecast",
        "ambiguous",
        "unsupported"
      ],
      "title": "QueryType",
      "type": "string"
    },
    "RenderStyle": {
      "description": "Whether the answer should be formatted deterministically or via LLM narrative.",
      "enum": [
        "deterministic",
        "narrative"
      ],
      "title": "RenderStyle",
      "type": "string"
    },
    "RoutingInfo": {
      "additionalProperties": false,
      "properties": {
        "preferred_path": {
          "$ref": "#/$defs/PreferredPath"
        },
        "needs_sql": {
          "title": "Needs Sql",
          "type": "boolean"
        },
        "needs_knowledge": {
          "title": "Needs Knowledge",
          "type": "boolean"
        },
        "prefer_tool": {
          "title": "Prefer Tool",
          "type": "boolean"
        },
        "needs_multi_tool": {
          "default": false,
          "title": "Needs Multi Tool",
          "type": "boolean"
        },
        "evidence_roles": {
          "items": {
            "$ref": "#/$defs/EvidenceRole"
          },
          "maxItems": 4,
          "title": "Evidence Roles",
          "type": "array"
        }
      },
      "required": [
        "preferred_path",
        "needs_sql",
        "needs_knowledge",
        "prefer_tool"
      ],
      "title": "RoutingInfo",
      "type": "object"
    },
    "ScenarioAggregation": {
      "enum": [
        "sum",
        "mean",
        "min",
        "max"
      ],
      "title": "ScenarioAggregation",
      "type": "string"
    },
    "Season": {
      "enum": [
        "summer",
        "winter",
        "full"
      ],
      "title": "Season",
      "type": "string"
    },
    "SemanticRole": {
      "enum": [
        "observed",
        "reference",
        "derived",
        "component_primary",
        "component_secondary"
      ],
      "title": "SemanticRole",
      "type": "string"
    },
    "SeriesSplitMode": {
      "enum": [
        "single_chart",
        "multi_panel"
      ],
      "title": "SeriesSplitMode",
      "type": "string"
    },
    "SortRule": {
      "enum": [
        "value_desc",
        "value_asc",
        "time_asc",
        "time_desc",
        "category_alpha",
        "relevance"
      ],
      "title": "SortRule",
      "type": "string"
    },
    "SqlAggregation": {
      "enum": [
        "none",
        "daily",
        "monthly",
        "quarterly",
        "yearly"
      ],
      "title": "SqlAggregation",
      "type": "string"
    },
    "SqlHints": {
      "additionalProperties": false,
      "properties": {
        "metric": {
          "anyOf": [
            {
              "maxLength": 64,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Metric"
        },
        "entities": {
          "items": {
            "type": "string"
          },
          "maxItems": 25,
          "title": "Entities",
          "type": "array"
        },
        "aggregation": {
          "anyOf": [
            {
              "$ref": "#/$defs/SqlAggregation"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "dimensions": {
          "items": {
            "$ref": "#/$defs/DimensionName"
          },
          "maxItems": 8,
          "title": "Dimensions",
          "type": "array"
        },
        "period": {
          "anyOf": [
            {
              "$ref": "#/$defs/PeriodInfo"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "filter": {
          "anyOf": [
            {
              "$ref": "#/$defs/FilterCondition"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "title": "SqlHints",
      "type": "object"
    },
    "ToolCandidate": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "$ref": "#/$defs/ToolName"
        },
        "score": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Score",
          "type": "number"
        },
        "reason": {
          "anyOf": [
            {
              "maxLength": 240,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reason"
        },
        "params_hint": {
          "anyOf": [
            {
              "$ref": "#/$defs/ToolParamsHint"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "name",
        "score"
      ],
      "title": "ToolCandidate",
      "type": "object"
    },
    "ToolName": {
      "enum": [
        "get_prices",
        "get_tariffs",
        "get_generation_mix",
        "get_balancing_composition"
      ],
      "title": "ToolName",
      "type": "string"
    },
    "ToolParamsHint": {
      "additionalProperties": false,
      "properties": {
        "metric": {
          "anyOf": [
            {
              "maxLength": 64,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Metric"
        },
        "currency": {
          "anyOf": [
            {
              "maxLength": 16,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Currency"
        },
        "granularity": {
          "anyOf": [
            {
              "maxLength": 16,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Granularity"
        },
        "start_date": {
          "anyOf": [
            {
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Start Date"
        },
        "end_date": {
          "anyOf": [
            {
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "End Date"
        },
        "entities": {
          "items": {
            "type": "string"
          },
          "maxItems": 25,
          "title": "Entities",
          "type": "array"
        },
        "types": {
          "items": {
            "type": "string"
          },
          "maxItems": 25,
          "title": "Types",
          "type": "array"
        },
        "mode": {
          "anyOf": [
            {
              "maxLength": 32,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Mode"
        },
        "filter": {
          "anyOf": [
            {
              "$ref": "#/$defs/FilterCondition"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "title": "ToolParamsHint",
      "type": "object"
    },
    "ToolingInfo": {
      "additionalProperties": false,
      "properties": {
        "candidate_tools": {
          "items": {
            "$ref": "#/$defs/ToolCandidate"
          },
          "maxItems": 5,
          "title": "Candidate Tools",
          "type": "array"
        }
      },
      "title": "ToolingInfo",
      "type": "object"
    },
    "TopicCandidate": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "$ref": "#/$defs/KnowledgeTopicName"
        },
        "score": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Score",
          "type": "number"
        }
      },
      "required": [
        "name",
        "score"
      ],
      "title": "TopicCandidate",
      "type": "object"
    },
    "VisualGoal": {
      "enum": [
        "trend",
        "compare",
        "composition",
        "decomposition",
        "ranking",
        "relationship",
        "threshold_scan"
      ],
      "title": "VisualGoal",
      "type": "string"
    },
    "VisualizationInfo": {
      "additionalProperties": false,
      "properties": {
        "chart_requested_by_user": {
          "title": "Chart Requested By User",
          "type": "boolean"
        },
        "chart_recommended": {
          "title": "Chart Recommended",
          "type": "boolean"
        },
        "chart_confidence": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Chart Confidence",
          "type": "number"
        },
        "preferred_chart_family": {
          "anyOf": [
            {
              "$ref": "#/$defs/ChartFamily"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "primary_presentation": {
          "anyOf": [
            {
              "$ref": "#/$defs/PresentationMode"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "visual_goal": {
          "anyOf": [
            {
              "$ref": "#/$defs/VisualGoal"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "measure_transform": {
          "$ref": "#/$defs/MeasureTransform",
          "default": "raw"
        },
        "time_grain": {
          "anyOf": [
            {
              "$ref": "#/$defs/VisualizationTimeGrain"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "series_split_mode": {
          "$ref": "#/$defs/SeriesSplitMode",
          "default": "single_chart"
        },
        "max_series": {
          "anyOf": [
            {
              "maximum": 8,
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Series"
        },
        "sort_rule": {
          "anyOf": [
            {
              "$ref": "#/$defs/SortRule"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "top_n": {
          "anyOf": [
            {
              "maximum": 50,
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Top N"
        },
        "chart_intent": {
          "anyOf": [
            {
              "$ref": "#/$defs/ChartIntent"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "target_series": {
          "items": {
            "$ref": "#/$defs/SemanticRole"
          },
          "maxItems": 5,
          "title": "Target Series",
          "type": "array"
        }
      },
      "required": [
        "chart_requested_by_user",
        "chart_recommended",
        "chart_confidence"
      ],
      "title": "VisualizationInfo",
      "type": "object"
    },
    "VisualizationTimeGrain": {
      "enum": [
        "raw",
        "day",
        "month",
        "quarter",
        "season",
        "year"
      ],
      "title": "VisualizationTimeGrain",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Validated output for the question-analyzer LLM call.",
  "properties": {
    "version": {
      "const": "question_analysis_v1",
      "title": "Version",
      "type": "string"
    },
    "raw_query": {
      "maxLength": 2000,
      "minLength": 1,
      "title": "Raw Query",
      "type": "string"
    },
    "canonical_query_en": {
      "maxLength": 2000,
      "minLength": 1,
      "title": "Canonical Query En",
      "type": "string"
    },
    "language": {
      "$ref": "#/$defs/LanguageInfo"
    },
    "classification": {
      "$ref": "#/$defs/ClassificationInfo"
    },
    "routing": {
      "$ref": "#/$defs/RoutingInfo"
    },
    "knowledge": {
      "$ref": "#/$defs/KnowledgeInfo"
    },
    "tooling": {
      "$ref": "#/$defs/ToolingInfo"
    },
    "sql_hints": {
      "$ref": "#/$defs/SqlHints"
    },
    "visualization": {
      "$ref": "#/$defs/VisualizationInfo"
    },
    "analysis_requirements": {
      "$ref": "#/$defs/AnalysisRequirementsInfo"
    },
    "answer_kind": {
      "anyOf": [

{
  "$schema": "./metric_units_v1.schema.json",
  "schema_version": 1,
  "registry_version": "1.0.0",
  "metrics": {
    "price.gel": {
      "source_metrics": ["p_bal_gel", "p_dereg_gel", "p_gcap_gel", "balancing_price_gel", "deregulated_price_gel", "guaranteed_capacity_price_gel"],
      "source_metric_patterns": [],
      "dimension": "currency_gel_per_energy",
      "storage_unit": "GEL/MWh",
      "canonical_unit": "tetri/kWh",
      "display_unit": "tetri/kWh",
      "to_canonical_factor": 0.1,
      "compatible_aggregations": ["mean", "min", "max", "median"],
      "precision": 3,
      "filter_unit_aliases": {
        "gel/mwh": 0.1,
        "tetri/kwh": 1.0,
        "tetri": 1.0
      }
    },
    "price.usd": {
      "source_metrics": ["p_bal_usd", "p_dereg_usd", "p_gcap_usd", "balancing_price_usd", "deregulated_price_usd", "guaranteed_capacity_price_usd"],
      "source_metric_patterns": [],
      "dimension": "currency_usd_per_energy",
      "storage_unit": "USD/MWh",
      "canonical_unit": "USD cents/kWh",
      "display_unit": "USD cents/kWh",
      "to_canonical_factor": 0.1,
      "compatible_aggregations": ["mean", "min", "max", "median"],
      "precision": 3,
      "filter_unit_aliases": {
        "usd/mwh": 0.1,
        "usd cents/kwh": 1.0,
        "usd cent/kwh": 1.0,
        "cents/kwh": 1.0,
        "cent/kwh": 1.0
      }
    },
    "tariff.gel": {
      "source_metrics": ["tariff_gel"],
      "source_metric_patterns": ["*_tariff_gel"],
      "dimension": "currency_gel_per_energy",
      "storage_unit": "GEL/MWh",
      "canonical_unit": "GEL/MWh",
      "display_unit": "GEL/MWh",
      "to_canonical_factor": 1.0,
      "compatible_aggregations": ["mean", "min", "max", "median"],
      "precision": 3,
      "filter_unit_aliases": {
        "gel/mwh": 1.0,
        "tetri/kwh": 10.0,
        "tetri": 10.0
      }
    },
    "tariff.usd": {
      "source_metrics": ["tariff_usd"],
      "source_metric_patterns": ["*_tariff_usd"],
      "dimension": "currency_usd_per_energy",
      "storage_unit": "USD/MWh",
      "canonical_unit": "USD/MWh",
      "display_unit": "USD/MWh",
      "to_canonical_factor": 1.0,
      "compatible_aggregations": ["mean", "min", "max", "median"],
      "precision": 3,
      "filter_unit_aliases": {
        "usd/mwh": 1.0,
        "usd cents/kwh": 10.0,
        "usd cent/kwh": 10.0,
        "cents/kwh": 10.0,
        "cent/kwh": 10.0
      }
    },
    "energy.quantity": {
      "source_metrics": ["quantity_tech", "generation_quantity", "total_demand", "total_domestic_generation", "local_generation", "import_dependent_supply", "total_supply"],
      "source_metric_patterns": ["quantity_*"],
      "dimension": "energy",
      "storage_unit": "thousand MWh",
      "canonical_unit": "MWh",
      "display_unit": "MWh",
      "to_canonical_factor": 1000.0,
      "compatible_aggregations": ["sum", "mean", "min", "max", "median"],
      "precision": 3,
      "filter_unit_aliases": {
        "thousand mwh": 1000.0,
        "mwh": 1.0,
        "gwh": 1000.0
      }
    },
    "ratio.share": {
      "source_metrics": ["generation_share", "balancing_share", "import_dependency_ratio"],
      "source_metric_patterns": ["share_*"],
      "dimension": "dimensionless_ratio",
      "storage_unit": "ratio",
      "canonical_unit": "%",
      "display_unit": "%",
      "to_canonical_factor": 100.0,
      "compatible_aggregations": ["mean", "min", "max", "median"],
      "precision": 2,
      "filter_unit_aliases": {
        "ratio": 100.0,
        "%": 1.0,
        "percent": 1.0,
        "percentage": 1.0
      }
    },
    "exchange_rate.gel_usd": {
      "source_metrics": ["xrate", "exchange_rate"],
      "source_metric_patterns": [],
      "dimension": "exchange_rate_gel_per_usd",
      "storage_unit": "GEL/USD",
      "canonical_unit": "GEL/USD",
      "display_unit": "GEL/USD",
      "to_canonical_factor": 1.0,
      "compatible_aggregations": ["mean", "min", "max", "median"],
      "precision": 4,
      "filter_unit_aliases": {
        "gel/usd": 1.0
      }
    }
  }
}

            "code": {
              "title": "Code",
              "type": "string"
            },
            "message": {
              "title": "Message",
              "type": "string"
            },
            "request_id": {
              "title": "Request Id",
              "type": "string"
            },
            "retryable": {
              "title": "Retryable",
              "type": "boolean"
            }
          },
          "required": [
            "code",
            "message",
            "retryable",
            "request_id"
          ],
          "title": "APIErrorDetail",
          "type": "object"
        }
      },
      "additionalProperties": false,
      "description": "Versioned /ask error envelope.",
      "properties": {
        "error": {
          "$ref": "#/$defs/APIErrorDetail"
        }
      },
      "required": [
        "error"
      ],
      "title": "APIErrorResponse",
      "type": "object"

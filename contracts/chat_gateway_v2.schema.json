    "Question": {
      "$defs": {
        "ConversationTurn": {
          "additionalProperties": false,
          "description": "One caller-supplied Q&A pair accepted by the chat API.",
          "properties": {
            "answer": {
              "default": "",
              "maxLength": 2000,
              "title": "Answer",
              "type": "string"
            },
            "question": {
              "maxLength": 2000,
              "minLength": 1,
              "title": "Question",
              "type": "string"
            }
          },
          "required": [
            "question"
          ],
          "title": "ConversationTurn",
          "type": "object"
        }
      },
      "additionalProperties": false,
      "description": "User question model for /ask endpoint.\n\nAttributes:\n    query: Natural language query in English, Georgian, or Russian\n    user_id: Legacy non-authoritative correlation label; never identity\n    conversation_history: Optional list of previous Q&A pairs for context",
      "properties": {
        "conversation_history": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/ConversationTurn"
              },
              "maxItems": 3,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Last 1-3 Q&A pairs: [{'question': '...', 'answer': '...'}]",
          "title": "Conversation History"
        },
        "query": {
          "description": "Natural language query",
          "maxLength": 2000,
          "title": "Query",
          "type": "string"
        },
        "user_id": {
          "anyOf": [
            {
              "maxLength": 128,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Legacy non-authoritative label; ignored for identity and authorization",
          "title": "User Id"
        }
      },
      "required": [
        "query"
      ],
      "title": "Question",
      "type": "object"
    }

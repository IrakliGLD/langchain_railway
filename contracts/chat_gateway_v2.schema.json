    "ConversationTurn": {
      "additionalProperties": false,
      "description": "One caller-supplied Q&A pair accepted by the chat API.",
      "properties": {
        "answer": {
          "default": "",
          "maxLength": 2000,
          "title": "Answer",
          "type": "string"

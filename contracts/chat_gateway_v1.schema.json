              "maxItems": 3,
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Last 1-3 Q&A pairs: [{'question': '...', 'answer': '...'}]",
          "title": "Conversation History"
        },
        "query": {
          "description": "Natural language query",
          "maxLength": 2000,
          "title": "Query",
          "type": "string"
        },
        "user_id": {
          "anyOf": [
            {
              "maxLength": 128,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Legacy non-authoritative label; ignored for identity and authorization",
          "title": "User Id"
        }
      },
      "required": [
        "query"
      ],
      "title": "Question",
      "type": "object"
    }
  }
